{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "nixpacksPlan": {
      "nixpkgs": ["python3", "pip", "curl"]
    }
  },
  "deploy": {
    "numReplicas": 1,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10,
    "runtime": {
      "port": 5005,
      "command": "cd backend && pip install -r requirements.txt && gunicorn -w 4 -b 0.0.0.0:$PORT app:app"
    }
  }
}
